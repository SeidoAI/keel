name: Tripwire checks

on:
  pull_request:
  push:
    branches: [main, master]

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      # setup-uv pinned to v8.1.0 (point release) — v8 dropped the
      # floating major tag per its immutable-tag policy.
      - uses: astral-sh/setup-uv@v8.1.0
        with:
          python-version: "3.13"
      - name: Install tripwire
        run: uv tool install tripwire-pm=={{ tripwire_version }}
      - name: Validate (strict)
        run: tripwire validate --strict --format=json
      - name: Lint scoping
        run: tripwire lint scoping
      - name: Lint handoff
        run: tripwire lint handoff
      - name: Lint session
        run: tripwire lint session
      - name: Brief (smoke test)
        run: tripwire brief --format=json > /dev/null
