# {{ project_name }} — tripwire config
# Generated by `tripwire init`. Edit freely.

name: {{ project_name }}
key_prefix: {{ key_prefix }}
description: {{ description | default("", true) }}
base_branch: {{ base_branch }}
environments: [test, prod]

# Repository registry — GitHub slug → local clone path (optional).
# Add `local: ~/path/to/clone` under each repo to speed up freshness checks.
repos:
{%- if repos %}
{%- for repo in repos %}
  {{ repo }}:
    local: null
{%- endfor %}
{%- else %}
  # e.g. SeidoAI/web-app-backend:
  #   local: ~/Code/seido/web-app
  {}
{%- endif %}

# Issue lifecycle statuses. These must match an entry in enums/issue_status.yaml.
# Default 6-stage flow: backlog → todo → in_progress → in_review → verified → done.
statuses:
  - backlog
  - todo
  - in_progress
  - in_review
  - verified
  - done
  - canceled

# Directed graph of allowed status transitions. The validator checks that
# every issue's status is reachable from `backlog` via these transitions.
status_transitions:
  backlog: [todo, canceled]
  todo: [in_progress, backlog, canceled]
  in_progress: [in_review, todo, canceled]
  in_review: [verified, in_progress]
  verified: [done, in_review]
  done: []
  canceled: [backlog]

# Label categories for the validator to check against.
label_categories:
  executor: [ai, human, mixed]
  verifier: [required, optional, none]
  domain: []
  agent: []

# Concept graph settings.
graph:
  node_types:
    - endpoint
    - model
    - config
    - tf_output
    - contract
    - decision
    - requirement
    - service
    - schema
    - custom
  auto_index: true

# Orchestration default (Step 5+ — expand in a later release).
orchestration:
  default_pattern: default
  plan_approval_required: false
  auto_merge_on_pass: false

# Sequential key counters. Do NOT edit by hand — use `tripwire next-key`.
next_issue_number: 1
next_session_number: 1

# Workflow phase — the validator enforces phase-specific requirements.
# Phases: scoping → scoped → executing → reviewing
# The PM agent advances this after completing each phase's requirements.
phase: scoping

created_at: "{{ created_at }}"

# Pinned tripwire version — read by `tripwire ci install` to pin the
# generated `.github/workflows/tripwire.yml` workflow.
tripwire_version: "{{ tripwire_version }}"
