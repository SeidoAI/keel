# {{ project_name }} — tripwire config
# Generated by `tripwire init`. Edit freely.

name: {{ project_name }}
key_prefix: {{ key_prefix }}
description: {{ description | default("", true) }}
base_branch: {{ base_branch }}
environments: [test, prod]

# Repository registry — GitHub slug → local clone path.
# `local` must point at a clone on disk for `tripwire session spawn`
# to create worktrees. Leave null and fill in later if you need to.
repos:
{%- if repos %}
{%- for slug in repos %}
  {{ slug }}:
{%- if repos_locals and repos_locals[slug] %}
    local: {{ repos_locals[slug] }}
{%- else %}
    local: null
{%- endif %}
{%- endfor %}
{%- else %}
  # e.g. SeidoAI/web-app-backend:
  #   local: ~/Code/seido/web-app
  {}
{%- endif %}

# Issue lifecycle statuses (v0.9.4 — aligned with SessionStatus). Must match
# an entry in enums/issue_status.yaml. Canonical 7-stage flow:
# planned → queued → executing → in_review → verified → completed.
# `abandoned` is the not-claimed-success terminal; `deferred` is for
# issues consciously skipped within a session that carry forward.
statuses:
  - planned
  - queued
  - executing
  - in_review
  - verified
  - completed
  - abandoned
  - deferred

# Directed graph of allowed status transitions. The validator checks that
# every issue's status is reachable from `planned` via these transitions.
status_transitions:
  planned: [queued, abandoned]
  queued: [executing, planned, abandoned]
  executing: [in_review, queued, abandoned]
  in_review: [verified, executing]
  verified: [completed, in_review]
  completed: []
  abandoned: [planned]
  deferred: [planned, queued, abandoned]

# Label categories for the validator to check against.
label_categories:
  executor: [ai, human, mixed]
  verifier: [required, optional, none]
  domain: []
  agent: []

# Concept graph settings.
graph:
  node_types:
    - endpoint
    - model
    - config
    - tf_output
    - contract
    - decision
    - requirement
    - service
    - schema
    - custom
  auto_index: true

# Orchestration default (Step 5+ — expand in a later release).
orchestration:
  default_pattern: default
  plan_approval_required: false
  auto_merge_on_pass: false

# v0.8.0 (KUI-99) — tripwire primitive opt-out + project-local extras.
# Tripwires are hidden prompts registered against lifecycle events;
# the canonical first one (self-review on session.complete) ships
# enabled. Set `enabled: false` to disable ALL tripwires (including
# the pre-push hook installed at session-spawn time). `opt_out` skips
# tripwires for specific sessions; `extra` registers project-local
# tripwires loaded from the project's own Python modules.
tripwires:
  enabled: true
  opt_out: []
  extra: []

# v0.7.9 — required artifacts (the correctness contract). Sessions and
# issues with `status: done` must have every file below committed to the
# merged-main snapshot of the project tracking repo. Validator rule
# `done_implies_artifacts_on_main` enforces this. See spec §A1.
artifact_manifest:
  session_required:
    - task-checklist.md
    - verification-checklist.md
    - self-review.md
    - pm-response.yaml
    - insights.yaml
  issue_required:
    - developer.md
    - verified.md

# Sequential key counters. Do NOT edit by hand — use `tripwire next-key`.
next_issue_number: 1
next_session_number: 1

# Workflow phase — the validator enforces phase-specific requirements.
# Phases: scoping → scoped → executing → reviewing
# The PM agent advances this after completing each phase's requirements.
phase: scoping

created_at: "{{ created_at }}"

# Pinned tripwire version — read by `tripwire ci install` to pin the
# generated `.github/workflows/tripwire.yml` workflow.
tripwire_version: "{{ tripwire_version }}"
{% if project_repo_url %}
# SSH URL of this project-tracking repo on GitHub. Set by `tripwire init`
# (v0.7.6) when the GitHub repo is auto-created or an existing one is wired up.
project_repo_url: {{ project_repo_url }}
{% endif %}
