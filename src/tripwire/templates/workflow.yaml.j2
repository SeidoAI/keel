# Per-project workflow definitions. v0.9 ships `coding-session`; later
# versions add `inbox-handling`, `issue-lifecycle`, `concept-freshness`,
# `pr-lifecycle`. Each workflow is a typed lifecycle graph: stations
# with declared validators, tripwires, and prompt-checks; transitions
# between stations gated by the runtime; an append-only events log
# substrate.
#
# Schema reference: docs/specs/2026-04-30-v09-workflow-substrate.md
#
# Conditional next: equality only (`==`, `!=`). Predicate fields are
# dot-paths into the workflow context (e.g. `agent.role`).

workflows:
  coding-session:
    actor: coding-agent
    trigger: session.spawn
    stations:
      - id: planned
        next: queued
      - id: queued
        next: executing
      - id: executing
        next: in_review
      - id: in_review
        next: verified
      - id: verified
        next: completed
      - id: completed
        terminal: true
    # NOTE: v0.9 ships the gate runner (KUI-159) that READS
    # `prompt_check.invoked` events, but no caller in this codebase
    # yet EMITS them. The PM slash-commands wired with `fires_at:`
    # (KUI-122) carry the station mapping but not the per-invocation
    # event emit. Until the producer side lands (v0.9.x follow-up),
    # declaring `prompt_checks: [...]` here would make every real
    # `tripwire transition` reject with `prompt_checks_missing`.
    # The schema still supports prompt_checks; this template will
    # gain the declarations once the producer is wired.
